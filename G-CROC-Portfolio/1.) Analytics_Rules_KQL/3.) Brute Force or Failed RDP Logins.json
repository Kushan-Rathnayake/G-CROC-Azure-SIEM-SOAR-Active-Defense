{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "workspace": {
            "type": "String"
        }
    },
    "resources": [
        {
            "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspace'), 'Microsoft.SecurityInsights'),'/alertRules/f9c0d57d-7d88-49f7-96d6-eee746beb7a8')]",
            "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/f9c0d57d-7d88-49f7-96d6-eee746beb7a8')]",
            "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
            "kind": "Scheduled",
            "apiVersion": "2023-12-01-preview",
            "properties": {
                "displayName": "Brute Force / Failed RDP Logins",
                "description": "",
                "severity": "Medium",
                "enabled": true,
                "query": "SecurityEvent\n| where EventID == 4625\n| where IpAddress != \"-\" and isnotempty(IpAddress)\n| where ipv4_is_private(IpAddress) == false\n| extend GeoInfo = geo_info_from_ip_address(IpAddress)\n| extend Country = tostring(GeoInfo.country)\n| extend AlertSeverity = iff(TargetUserName in~ (\"Administrator\", \"Admin\", \"root\"), \"High\", \"Medium\")\n| project TimeGenerated, Computer, Account, TargetUserName, IpAddress, LogonTypeName, Status, SubStatus, Country, AlertSeverity",
                "queryFrequency": "PT5M",
                "queryPeriod": "PT1H",
                "triggerOperator": "GreaterThan",
                "triggerThreshold": 5,
                "suppressionDuration": "PT10M",
                "suppressionEnabled": true,
                "startTimeUtc": null,
                "tactics": [
                    "InitialAccess",
                    "CredentialAccess",
                    "LateralMovement"
                ],
                "techniques": [
                    "T1110",
                    "T1021",
                    "T1133"
                ],
                "subTechniques": [
                    "T1021.001"
                ],
                "alertRuleTemplateName": null,
                "incidentConfiguration": {
                    "createIncident": true,
                    "groupingConfiguration": {
                        "enabled": true,
                        "reopenClosedIncident": false,
                        "lookbackDuration": "PT5H",
                        "matchingMethod": "AllEntities",
                        "groupByEntities": [],
                        "groupByAlertDetails": [],
                        "groupByCustomDetails": []
                    }
                },
                "eventGroupingSettings": {
                    "aggregationKind": "SingleAlert"
                },
                "alertDetailsOverride": {
                    "alertDisplayNameFormat": "Brute Force Attempt from IP: {{IpAddress}}",
                    "alertDescriptionFormat": "The account {{TargetUserName}} is being targeted by a brute force attack from {{IpAddress}} located in {{Country}}.",
                    "alertSeverityColumnName": "AlertSeverity",
                    "alertDynamicProperties": []
                },
                "customDetails": {
                    "Logon_Type": "LogonTypeName",
                    "Fail_Reason": "SubStatus",
                    "Attacker_Country": "Country"
                },
                "entityMappings": [
                    {
                        "entityType": "Account",
                        "fieldMappings": [
                            {
                                "identifier": "Name",
                                "columnName": "TargetUserName"
                            }
                        ]
                    },
                    {
                        "entityType": "IP",
                        "fieldMappings": [
                            {
                                "identifier": "Address",
                                "columnName": "IpAddress"
                            }
                        ]
                    },
                    {
                        "entityType": "Host",
                        "fieldMappings": [
                            {
                                "identifier": "HostName",
                                "columnName": "Computer"
                            }
                        ]
                    }
                ],
                "sentinelEntitiesMappings": null,
                "templateVersion": null
            }
        }
    ]
}